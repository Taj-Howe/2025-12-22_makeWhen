{
  "name": "makewhen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "echo \"TODO: lint\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "pnpm -s typecheck && pnpm -s build",
    "smoke": "node --no-warnings=ExperimentalWarning --experimental-strip-types scripts/smoke.ts",
    "sync-server:dev": "pnpm --dir apps/sync-server dev",
    "sync-server:start": "pnpm --dir apps/sync-server start",
    "sync-server:migrate": "pnpm --dir apps/sync-server migrate",
    "sync-server:smoke": "pnpm --dir apps/sync-server smoke",
    "sync-server:e2e": "pnpm --dir apps/sync-server e2e",
    "sync-server:verify": "pnpm --dir apps/sync-server verify"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.2.1",
    "@sqlite.org/sqlite-wasm": "3.51.1-build2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
